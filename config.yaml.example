# 阿里云 DDNS 配置文件示例
# 注意：请将此文件复制为 config.yaml 并填写您的实际配置信息

access_key_id: YOUR_ACCESS_KEY_ID
access_key_secret: YOUR_ACCESS_KEY_SECRET
domain: example.com
interval: 300
records:
- rr: '@'
  type: A
- rr: www
  type: A
ttl: 600

# 配置项说明：
# access_key_id 和 access_key_secret：阿里云账号的访问密钥
# domain：要进行动态解析的域名
# records：要同步的 DNS 记录列表
# interval：自动同步的时间间隔（秒）
# ttl：DNS 记录的生存时间（秒）